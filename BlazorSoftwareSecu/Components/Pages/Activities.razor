@page "/activities"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using BlazorSoftwareSecu.Data
@using BlazorSoftwareSecu.Models

@inject ApplicationDbContext DbContext
@inject AuthenticationStateProvider AuthenticationStateProvider

<h1>Traumeterapeutiske aktiviteter</h1>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-success">@Message</div>
}

@if (activities.Count == 0)
{
    <p>Der findes ingen aktiviteter endnu.</p>
}
else
{
    @foreach (var activity in activities)
    {
        var isEnrolled = enrolledActivityIds.Contains(activity.Id);

        <div class="card mb-3">
            <div class="card-body">
                <h4>@activity.Title</h4>
                <p>@activity.Description</p>
                <p><strong>Dato:</strong> @activity.Date.ToString("dd-MM-yyyy HH:mm")</p>

                @if (isEnrolled)
                {
                    <button class="btn btn-danger" @onclick="() => Unenroll(activity.Id)">
                        Afmeld
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="() => Enroll(activity.Id)">
                        Tilmeld
                    </button>
                }
            </div>
        </div>
    }
}

@code {
    private List<Activity> activities = new();
    private HashSet<int> enrolledActivityIds = new();
    private string? Message;
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        activities = await DbContext.Activities
            .OrderBy(a => a.Date)
            .ToListAsync();

        if (userId is not null)
        {
            enrolledActivityIds = await DbContext.Enrollments
                .Where(e => e.UserId == userId)
                .Select(e => e.ActivityId)
                .ToHashSetAsync();
        }
    }

    private async Task Enroll(int activityId)
    {
        if (userId is null)
        {
            return;
        }

        var alreadyEnrolled = await DbContext.Enrollments
            .AnyAsync(e => e.UserId == userId && e.ActivityId == activityId);

        if (alreadyEnrolled)
        {
            Message = "Du er allerede tilmeldt denne aktivitet.";
            return;
        }

        DbContext.Enrollments.Add(new Enrollment
        {
            UserId = userId,
            ActivityId = activityId
        });

        await DbContext.SaveChangesAsync();

        enrolledActivityIds.Add(activityId);

        Message = "Du er nu tilmeldt aktiviteten.";
    }

    private async Task Unenroll(int activityId)
    {
        if (userId is null)
        {
            return;
        }

        var enrollment = await DbContext.Enrollments
            .FirstOrDefaultAsync(e => e.UserId == userId && e.ActivityId == activityId);

        if (enrollment is null)
        {
            return;
        }

        DbContext.Enrollments.Remove(enrollment);

        await DbContext.SaveChangesAsync();

        enrolledActivityIds.Remove(activityId);

        Message = "Du er nu afmeldt aktiviteten.";
    }
}