@page "/activities"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using BlazorSoftwareSecu.Data
@using BlazorSoftwareSecu.Models

@inject ApplicationDbContext DbContext
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Aktiviteter</PageTitle>

<div class="container py-4">

    <div class="mb-4">
        <h1 class="fw-bold">Traumeterapeutiske aktiviteter</h1>
        <p class="text-muted">
            Her kan du se sundhedscenterets aktuelle aktiviteter og tilmelde eller afmelde dig.
        </p>
    </div>

    @if (!string.IsNullOrEmpty(Message))
    {
        <div class="alert alert-success rounded-3 shadow-sm">
            @Message
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <h6 class="text-muted">Aktiviteter</h6>
                    <h2 class="fw-bold">@activities.Count</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <h6 class="text-muted">Mine tilmeldinger</h6>
                    <h2 class="fw-bold">@enrolledActivityIds.Count</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <h6 class="text-muted">Ledige aktiviteter</h6>
                    <h2 class="fw-bold">@(activities.Count - enrolledActivityIds.Count)</h2>
                </div>
            </div>
        </div>
    </div>

    @if (activities.Count == 0)
    {
        <div class="alert alert-info">
            Der findes ingen aktiviteter endnu.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var activity in activities)
            {
                var isEnrolled = enrolledActivityIds.Contains(activity.Id);

                <div class="col-md-6 col-xl-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100">

                        <div class="card-body p-4 d-flex flex-column">

                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <h4 class="fw-bold mb-0">
                                    @activity.Title
                                </h4>

                                @if (isEnrolled)
                                {
                                    <span class="badge bg-success">
                                        Tilmeldt
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Ledig
                                    </span>
                                }
                            </div>

                            <p class="text-muted flex-grow-1">
                                @activity.Description
                            </p>

                            <div class="border-top pt-3 mt-3">
                                <p class="mb-3">
                                    <strong>Dato:</strong>
                                    @activity.Date.ToString("dd-MM-yyyy HH:mm")
                                </p>

                                @if (isEnrolled)
                                {
                                    <button class="btn btn-outline-danger w-100"
                                            @onclick="() => Unenroll(activity.Id)">
                                        Afmeld aktivitet
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-success w-100"
                                            @onclick="() => Enroll(activity.Id)">
                                        Tilmeld aktivitet
                                    </button>
                                }
                            </div>

                        </div>

                    </div>
                </div>
            }
        </div>
    }

</div>

@code {
    private List<Activity> activities = new();
    private HashSet<int> enrolledActivityIds = new();
    private string? Message;
    private string? userId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        activities = await DbContext.Activities
            .OrderBy(a => a.Date)
            .ToListAsync();

        if (userId is not null)
        {
            enrolledActivityIds = await DbContext.Enrollments
                .Where(e => e.UserId == userId)
                .Select(e => e.ActivityId)
                .ToHashSetAsync();
        }
    }

    private async Task Enroll(int activityId)
    {
        if (userId is null)
        {
            return;
        }

        var alreadyEnrolled = await DbContext.Enrollments
            .AnyAsync(e => e.UserId == userId && e.ActivityId == activityId);

        if (alreadyEnrolled)
        {
            Message = "Du er allerede tilmeldt denne aktivitet.";
            return;
        }

        DbContext.Enrollments.Add(new Enrollment
        {
            UserId = userId,
            ActivityId = activityId
        });

        await DbContext.SaveChangesAsync();

        enrolledActivityIds.Add(activityId);

        Message = "Du er nu tilmeldt aktiviteten.";
    }

    private async Task Unenroll(int activityId)
    {
        if (userId is null)
        {
            return;
        }

        var enrollment = await DbContext.Enrollments
            .FirstOrDefaultAsync(e => e.UserId == userId && e.ActivityId == activityId);

        if (enrollment is null)
        {
            return;
        }

        DbContext.Enrollments.Remove(enrollment);

        await DbContext.SaveChangesAsync();

        enrolledActivityIds.Remove(activityId);

        Message = "Du er nu afmeldt aktiviteten.";
    }
}