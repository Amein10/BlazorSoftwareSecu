@page "/"

<PageTitle>Albertslund Sundhedscenter</PageTitle>

<div class="container mt-4">

    <div class="text-center mb-4">
        <img src="images/logo.png"
             alt="Albertslund Sundhedscenter"
             class="img-fluid"
             style="max-width: 420px; margin-top: -30px;" />
    </div>

    <div class="p-5 mb-4 bg-light rounded-3 shadow">
        <div class="container-fluid py-4 text-center">

            <h1 class="display-5 fw-bold">
                Velkommen til Albertslund Sundhedscenter
            </h1>

            <p class="lead">
                Portal for pensionerede softwareudviklere med fokus på trivsel,
                heling og fællesskab.
            </p>

            <hr />

            <p>
                Her kan registrerede borgere se og tilmelde sig traumeterapeutiske
                aktiviteter, mindfulness-forløb og sociale arrangementer.
            </p>

            <AuthorizeView>
                <Authorized>
                    <a href="/activities" class="btn btn-primary btn-lg">
                        Se aktiviteter
                    </a>
                </Authorized>
                <NotAuthorized>
                    <a href="/Account/Register" class="btn btn-primary btn-lg me-2">
                        Opret bruger
                    </a>
                    <a href="/Account/Login" class="btn btn-outline-primary btn-lg">
                        Log ind
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>

    <div class="row">

        <div class="col-md-4">
            <div class="card shadow-sm mb-3 h-100">
                <div class="card-body">
                    <h4>Traumeterapi</h4>
                    <p>
                        Professionelle samtaler med fokus på stress,
                        arbejdstraumer og trivsel.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm mb-3 h-100">
                <div class="card-body">
                    <h4>Mindfulness</h4>
                    <p>
                        Afslapning, meditation og mentale værktøjer
                        til en roligere hverdag.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm mb-3 h-100">
                <div class="card-body">
                    <h4>Fællesskab</h4>
                    <p>
                        Sociale aktiviteter og netværk med andre
                        pensionerede softwareudviklere.
                    </p>
                </div>
            </div>
        </div>

    </div>

</div>