@page "/"

<PageTitle>Albertslund Sundhedscenter</PageTitle>

<div class="container py-4">

    <section class="text-center mb-4">
        <img src="images/logo.png"
             alt="Albertslund Sundhedscenter"
             class="img-fluid"
             style="max-width: 360px;" />
    </section>

    <section class="rounded-4 shadow p-5 text-center mb-4"
             style="background: linear-gradient(135deg, #f8fbfa, #eef5f2);">

        <h1 class="display-5 fw-bold mb-3">
            Velkommen til Albertslund Sundhedscenter
        </h1>

        <p class="lead mb-4">
            Et trygt digitalt sundhedstilbud for pensionerede softwareudviklere.
        </p>

        <p class="mb-4">
            Her kan du oprette en sikker brugerprofil, logge ind og tilmelde dig
            traumeterapeutiske aktiviteter, mindfulness-forløb og sociale arrangementer.
        </p>

        <AuthorizeView>
            <Authorized>
                <a href="/activities" class="btn btn-success btn-lg px-4">
                    Se aktiviteter
                </a>
            </Authorized>
        </AuthorizeView>
    </section>

    <section class="row g-4">

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold">Traumeterapi</h4>
                    <p class="text-muted">
                        Samtaler med fokus på stress, arbejdstraumer og psykisk trivsel.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold">Mindfulness</h4>
                    <p class="text-muted">
                        Øvelser og mentale værktøjer til ro, balance og restitution.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold">Fællesskab</h4>
                    <p class="text-muted">
                        Sociale aktiviteter og netværk med andre tidligere softwareudviklere.
                    </p>
                </div>
            </div>
        </div>

    </section>

</div>