@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using BlazorSoftwareSecu.Data

@inject UserManager<ApplicationUser> UserManager

<h1>Admin - Brugeradministration</h1>

@if (!string.IsNullOrEmpty(Message))
{
    <div class="alert alert-success">@Message</div>
}

@if (users.Count == 0)
{
    <p>Der findes ingen brugere.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Email</th>
                <th>CPR</th>
                <th>Roller</th>
                <th>Handlinger</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in users)
            {
                var isAdmin = userRoles[user.Id].Contains("Admin");

                <tr>
                    <td>@user.Email</td>
                    <td>@user.CPR</td>
                    <td>@string.Join(", ", userRoles[user.Id])</td>
                    <td>
                        @if (isAdmin)
                        {
                            <button class="btn btn-warning btn-sm me-2"
                                    @onclick="() => RemoveAdmin(user)">
                                Fjern Admin
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-success btn-sm me-2"
                                    @onclick="() => MakeAdmin(user)">
                                Gør Admin
                            </button>
                        }

                        <button class="btn btn-danger btn-sm"
                                @onclick="() => DeleteUser(user)">
                            Slet bruger
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ApplicationUser> users = new();
    private Dictionary<string, IList<string>> userRoles = new();
    private string? Message;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        users = await UserManager.Users.ToListAsync();
        userRoles.Clear();

        foreach (var user in users)
        {
            userRoles[user.Id] = await UserManager.GetRolesAsync(user);
        }
    }

    private async Task MakeAdmin(ApplicationUser user)
    {
        if (!await UserManager.IsInRoleAsync(user, "Admin"))
        {
            await UserManager.AddToRoleAsync(user, "Admin");
            Message = $"{user.Email} er nu Admin.";
        }

        await LoadUsers();
    }

    private async Task RemoveAdmin(ApplicationUser user)
    {
        if (await UserManager.IsInRoleAsync(user, "Admin"))
        {
            await UserManager.RemoveFromRoleAsync(user, "Admin");
            Message = $"{user.Email} er ikke længere Admin.";
        }

        await LoadUsers();
    }

    private async Task DeleteUser(ApplicationUser user)
    {
        var result = await UserManager.DeleteAsync(user);

        if (result.Succeeded)
        {
            Message = $"{user.Email} er slettet.";
        }
        else
        {
            Message = "Brugeren kunne ikke slettes.";
        }

        await LoadUsers();
    }
}