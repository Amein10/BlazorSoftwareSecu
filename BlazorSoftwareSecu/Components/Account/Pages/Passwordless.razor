@page "/passwordless"

<PageTitle>Passwordless</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            <div class="card border-0 shadow rounded-4">
                <div class="card-body p-5 text-center">

                    <h1 class="fw-bold mb-3">Passwordless login</h1>

                    <p class="text-muted mb-4">
                        Her kan du oprette og logge ind med passkey uden password.
                    </p>

                    <div class="d-grid gap-3">
                        <a href="/Account/RegisterPasskey"
                           class="btn btn-success btn-lg">
                            Opret bruger med passkey
                        </a>

                        <a href="/Account/LoginPasskey"
                           class="btn btn-outline-success btn-lg">
                            Log ind med passkey
                        </a>

                        <a href="/Account/Login"
                           class="btn btn-outline-secondary">
                            Tilbage til almindeligt login
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>