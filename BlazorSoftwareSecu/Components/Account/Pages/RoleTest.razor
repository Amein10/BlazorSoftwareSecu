@page "/roletest"
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization

<h1>Brugerinformation</h1>

<p>
    Her kan du se hvilken rolle den aktuelle bruger har.
</p>

<hr />

<AuthorizeView Roles="Borger">
    <Authorized>
        <div class="alert alert-info">
            <h4>👤 Borger</h4>
            <p>Du er logget ind som registreret borger.</p>
        </div>
    </Authorized>
</AuthorizeView>

<AuthorizeView Roles="Admin">
    <Authorized>
        <div class="alert alert-success">
            <h4>🔑 Administrator</h4>
            <p>Du har administratorrettigheder.</p>
        </div>
    </Authorized>
</AuthorizeView>

<AuthorizeView>
    <Authorized Context="authState">
        <div class="card mt-3">
            <div class="card-body">
                <h5>Aktuel bruger</h5>

                <p>
                    <strong>Email:</strong>
                    @authState.User.Identity?.Name
                </p>

                <p>
                    <strong>Admin:</strong>
                    @(authState.User.IsInRole("Admin") ? "Ja" : "Nej")
                </p>

                <p>
                    <strong>Borger:</strong>
                    @(authState.User.IsInRole("Borger") ? "Ja" : "Nej")
                </p>
            </div>
        </div>
    </Authorized>
</AuthorizeView>