@page "/admin/auditlogs"
@attribute [Authorize(Roles = "Admin")]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using BlazorSoftwareSecu.Data
@using BlazorSoftwareSecu.Models

@inject ApplicationDbContext DbContext

<PageTitle>Audit Logs</PageTitle>

<div class="container py-4">

    <div class="mb-4">
        <h1 class="fw-bold">Audit Logs</h1>
        <p class="text-muted">
            Her kan administrator se registrerede brugerhandlinger i systemet.
        </p>
    </div>

    @if (auditLogs.Count == 0)
    {
        <div class="alert alert-info">
            Der findes ingen logs endnu.
        </div>
    }
    else
    {
        <div class="card border-0 shadow rounded-4">
            <div class="card-body p-0">

                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Tidspunkt</th>
                            <th>BrugerId</th>
                            <th>Handling</th>
                            <th class="pe-4">Detaljer</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var log in auditLogs)
                        {
                            <tr>
                                <td class="ps-4">
                                    @log.Timestamp.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")
                                </td>
                                <td>
                                    <span class="text-muted">
                                        @log.UserId
                                    </span>
                                </td>
                                <td>
                                    <span class="badge bg-primary">
                                        @log.Action
                                    </span>
                                </td>
                                <td class="pe-4">
                                    @log.Details
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    }

</div>

@code {
    private List<AuditLog> auditLogs = new();

    protected override async Task OnInitializedAsync()
    {
        auditLogs = await DbContext.AuditLogs
            .OrderByDescending(log => log.Timestamp)
            .ToListAsync();
    }
}