@page "/Account/Manage/TwoFactorAuthentication"

@using Microsoft.AspNetCore.Http.Features
@using Microsoft.AspNetCore.Identity
@using BlazorSoftwareSecu.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>2-faktor login</PageTitle>

<div class="container py-4">

    <div class="mb-4">
        <h1 class="fw-bold">2-faktor login</h1>
        <p class="text-muted">
            Administrer ekstra loginbeskyttelse med en authenticator-app.
        </p>
    </div>

    <StatusMessage />

    @if (canTrack)
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body">
                        <h6 class="text-muted">Status</h6>

                        @if (is2faEnabled)
                        {
                            <span class="badge bg-success fs-6">Aktiveret</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary fs-6">Ikke aktiveret</span>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body">
                        <h6 class="text-muted">Authenticator-app</h6>

                        @if (hasAuthenticator)
                        {
                            <span class="badge bg-success fs-6">Opsat</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary fs-6">Mangler</span>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body">
                        <h6 class="text-muted">Recovery-koder</h6>
                        <h2 class="fw-bold">@recoveryCodesLeft</h2>
                    </div>
                </div>
            </div>
        </div>

        @if (is2faEnabled)
        {
            <div class="alert alert-success rounded-3 shadow-sm">
                Din konto er beskyttet med 2-faktor login.
            </div>

            @if (recoveryCodesLeft == 0)
            {
                <div class="alert alert-danger rounded-3">
                    <strong>Du har ingen recovery-koder tilbage.</strong>
                    <p class="mb-0">
                        Du bør generere nye recovery-koder, så du stadig kan få adgang,
                        hvis du mister din authenticator-app.
                    </p>
                </div>
            }
            else if (recoveryCodesLeft == 1)
            {
                <div class="alert alert-danger rounded-3">
                    <strong>Du har kun 1 recovery-kode tilbage.</strong>
                    <p class="mb-0">
                        Det anbefales at generere nye recovery-koder.
                    </p>
                </div>
            }
            else if (recoveryCodesLeft <= 3)
            {
                <div class="alert alert-warning rounded-3">
                    <strong>Du har kun @recoveryCodesLeft recovery-koder tilbage.</strong>
                    <p class="mb-0">
                        Det anbefales at generere nye recovery-koder snart.
                    </p>
                </div>
            }
        }
        else
        {
            <div class="alert alert-warning rounded-3 shadow-sm">
                2-faktor login er ikke aktiveret endnu. Aktiver det for at gøre din konto mere sikker.
            </div>
        }

        <div class="card border-0 shadow rounded-4">
            <div class="card-body p-4">

                <h4 class="fw-bold mb-3">Authenticator-app</h4>

                <p class="text-muted">
                    Brug Google Authenticator, Microsoft Authenticator eller en anden TOTP-app
                    til at beskytte din konto med en ekstra engangskode ved login.
                </p>

                <div class="d-flex flex-wrap gap-2 mt-3">

                    @if (!hasAuthenticator)
                    {
                        <a href="Account/Manage/EnableAuthenticator" class="btn btn-success">
                            Tilføj authenticator-app
                        </a>
                    }
                    else
                    {
                        <a href="Account/Manage/EnableAuthenticator" class="btn btn-success">
                            Konfigurer authenticator-app
                        </a>

                        <a href="Account/Manage/ResetAuthenticator" class="btn btn-outline-warning">
                            Nulstil authenticator-app
                        </a>
                    }

                    @if (is2faEnabled)
                    {
                        <a href="Account/Manage/GenerateRecoveryCodes" class="btn btn-outline-primary">
                            Generer nye recovery-koder
                        </a>

                        <a href="Account/Manage/Disable2fa" class="btn btn-outline-danger">
                            Deaktiver 2FA
                        </a>
                    }

                    @if (isMachineRemembered)
                    {
                        <form @formname="forget-browser"
                              @onsubmit="OnSubmitForgetBrowserAsync"
                              method="post">
                            <AntiforgeryToken />

                            <button type="submit" class="btn btn-outline-secondary">
                                Glem denne browser
                            </button>
                        </form>
                    }

                </div>

            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger rounded-3">
            <strong>Cookie-politikken er ikke accepteret.</strong>
            <p class="mb-0">
                Du skal acceptere cookie-politikken, før du kan aktivere 2-faktor login.
            </p>
        </div>
    }

</div>

@code {
    private bool canTrack;
    private bool hasAuthenticator;
    private int recoveryCodesLeft;
    private bool is2faEnabled;
    private bool isMachineRemembered;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        canTrack = HttpContext.Features.Get<ITrackingConsentFeature>()?.CanTrack ?? true;
        hasAuthenticator = await UserManager.GetAuthenticatorKeyAsync(user) is not null;
        is2faEnabled = await UserManager.GetTwoFactorEnabledAsync(user);
        isMachineRemembered = await SignInManager.IsTwoFactorClientRememberedAsync(user);
        recoveryCodesLeft = await UserManager.CountRecoveryCodesAsync(user);
    }

    private async Task OnSubmitForgetBrowserAsync()
    {
        await SignInManager.ForgetTwoFactorClientAsync();

        RedirectManager.RedirectToCurrentPageWithStatus(
            "Browseren er nu glemt. Næste gang du logger ind fra denne browser, skal du indtaste din 2FA-kode igen.",
            HttpContext);
    }
}